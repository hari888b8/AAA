# ============================================================
# AgriHub Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Server-side only

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=3600          # 1 hour in seconds
REFRESH_TOKEN_EXPIRY=604800  # 7 days in seconds

# ── SMS / OTP (MSG91) ───────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-otp-template-id
MSG91_SENDER_ID=AGRIHB

# ── SMS Fallback (Fast2SMS) ─────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── Payments (Razorpay) ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@agrihub.in

# ── Push Notifications (Firebase) ────────────────────────────
FIREBASE_PROJECT_ID=agrihub-prod
FIREBASE_SERVER_KEY=your-firebase-server-key

# ── WhatsApp (Meta WABA) ────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token

# ── Search (Meilisearch) ────────────────────────────────────
MEILISEARCH_HOST=https://your-instance.meilisearch.com
MEILISEARCH_API_KEY=your-meilisearch-master-key

# ── Media Storage (Cloudflare R2) ────────────────────────────
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=agrihub-media
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.agrihub.in

# ── Weather (IMD / OpenWeatherMap) ──────────────────────────
OPENWEATHERMAP_API_KEY=your-owm-api-key

# ── Maps ─────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# ── Feature Flags (GrowthBook) ──────────────────────────────
GROWTHBOOK_API_HOST=https://cdn.growthbook.io
GROWTHBOOK_CLIENT_KEY=sdk-your-key

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
VITE_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001/api/v1
